      X-Dns-Prefetch-Control: off
      X-Download-Options: noopen
      X-Permitted-Cross-Domain-Policies: none
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "responseCode": "02",
            "responseMessage": "ClientID wajib diisi",
            "responseData": null,
            "responseErrors": [
                {
                    "type": "validation",
                    "key": "ClientID",
                    "message": "ClientID wajib diisi"
                },
                {
                    "type": "validation",
