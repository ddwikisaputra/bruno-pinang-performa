  }
}

example {
  name: 404
  
  request: {
    url: {{base_url}}/v1/authentications/oauth2/token
    method: POST
    mode: json
    body:json: {
      {
         "clientId" : "test",
         "clientSecret" : "test"
      }
    }
  }
  
  response: {
    headers: {
      Date: Wed, 12 Feb 2025 06:43:25 GMT
      Content-Type: application/json
      Content-Length: 197
      X-Xss-Protection: 0
      X-Content-Type-Options: nosniff
      X-Frame-Options: SAMEORIGIN
      Cross-Origin-Embedder-Policy: require-corp
      Cross-Origin-Opener-Policy: same-origin
      Cross-Origin-Resource-Policy: same-origin
      Origin-Agent-Cluster: ?1
      Referrer-Policy: no-referrer
      X-Dns-Prefetch-Control: off
      X-Download-Options: noopen
      X-Permitted-Cross-Domain-Policies: none
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: json
      content: '''
        {
            "responseCode": "02",
            "responseMessage": "clientId or clientSecret not found",
            "responseData": null,
            "responseErrors": [
                {
                    "type": "message",
                    "key": "message",
                    "message": "clientId or clientSecret not found"
                }
            ]
        }
      '''
    }
  }
}
