example {
  name: unautorized
  
  request: {
    url: {{url}}/v/1/monitoring/list-loan-account
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 999941
      id: 802
      filterStatus: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 25 May 2022 07:06:28 GMT
      Content-Length: 106
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
            "code": 401,
            "desc": "Expired",
            "message": "Invalid Token || Token Is Expired"
        }
      '''
    }
  }
}

example {
  name: error parameter validation
  
  request: {
    url: {{url}}/v/1/monitoring/list-loan-account
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      id: 802
      filterStatus: 1
      ~userId: 999941
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 25 May 2022 07:06:28 GMT
      Content-Length: 106
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "Parameter ... Belum Terisi",
            "message": "Maaf, Parameter ... Belum Dipilih",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: error database connection
  
  request: {
    url: {{url}}/v/1/monitoring/list-loan-account
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 999941
      id: 802
      filterStatus: 1
