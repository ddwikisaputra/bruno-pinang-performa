example {
  name: Error - Validation PO sudah ditolak
  
  request: {
    url: {{url}}/v/1/partnerships/po-cancel-received
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 202312
      from: RAYAAPPS
      partnershipCode: OMS1
      userId: 1
      reason: Barang tidak diterima
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 20 Dec 2024 07:15:07 GMT
      Content-Length: 165
    }
  
    status: {
      code: 500
      text: Internal Server Error
    }
  
    body: {
      type: json
      content: '''
        {
            "status": 500,
            "message": "Maaf, Pengajuan anda sudah ditolak. Silahkan cek kembali status pengajuan anda.",
            "messageLocal": "PO Status < 0 (semua status ditolak)"
        }
      '''
    }
  }
}

