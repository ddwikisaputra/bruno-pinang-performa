      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Validation failed on field Id with tag 'required'",
            "message": "Maaf, Id Tidak Boleh Kosong",
            "status": 400
        }
      '''
    }
  }
}

