example {
  name: Error - PO Status not 1
  
  request: {
    url: {{url}}/v/1/partnerships/po-delivery-canceled
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      id: 567
      partnershipCode: OMS1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 20 Dec 2024 05:47:02 GMT
      Content-Length: 181
    }
  
    status: {
      code: 500
      text: Internal Server Error
    }
  
    body: {
      type: json
      content: '''
        {
            "status": 500,
            "message": "Maaf, Pengajuan anda sedang dalam proses. Silahkan tunggu hingga proses pengajuan selesai.",
            "messageLocal": "PO Status != 1 (sedang dalam proses pengajuan)"
        }
      '''
    }
  }
}

example {
  name: Error - Validation Param Required
  
  request: {
    url: {{url}}/v/1/partnerships/po-delivery-canceled
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      partnershipCode: OMS1
      ~id: 567
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
