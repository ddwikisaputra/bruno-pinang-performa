meta {
  name: Canceled Delivery Purchase Order V1
  type: http
  seq: 5
}

post {
  url: {{url}}/v/1/partnerships/po-delivery-canceled
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{tokenPartnership}}
}

body:form-urlencoded {
  userId: 15
  id: 40
  partnershipCode: OMS1
}

settings {
  encodeUrl: true
}

example {
  name: general error
  
  request: {
    url: {{url}}/v/1/partnerships/po-delivery-canceled
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      id: 1
      partnershipCode: OMS1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 02:53:38 GMT
      Content-Length: 111
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Could not connect .....",
            "message": "Server sedang maintenance, silahkan coba beberapa saat lagi",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: Success
  
  request: {
    url: {{base-url-local}}/v/1/partnerships/po-delivery-canceled
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      id: 567
      partnershipCode: OMS1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 20 Dec 2024 02:45:05 GMT
      Content-Length: 109
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "status": 200,
            "message": "Data pengiriman purchase order berhasil dibatalkan",
            "messageLocal": "Data Tersimpan"
        }
      '''
    }
  }
}

example {
  name: Error - Unauthorized
  
  request: {
    url: {{url}}/v/1/partnerships/po-delivery-canceled
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 10
      id: 567
      partnershipCode: OMS1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 20 Dec 2024 05:45:24 GMT
      Content-Length: 75
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
            "code": 401,
            "desc": "Expired",
            "message": "Invalid Token || Token Is Expired"
        }
      '''
    }
  }
}

