meta {
  name: List Purchase Order V1
  type: http
  seq: 10
}

post {
  url: {{url}}/v/1/partnerships/po-list
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{tokenPartnership}}
}

body:form-urlencoded {
  userId: 1
  startIndex: 0
  recordCount: 10
  partnershipCode: OMS1
  transactionalType: 1
  ~textSearch: Dwiki
}

settings {
  encodeUrl: true
}

example {
  name: success
  
  request: {
    url: {{url}}/v/1/partnerships/po-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      startIndex: 0
      recordCount: 10
      partnershipCode: PST2021
      transactionalType: 1
      ~textSearch: joko
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 03:03:58 GMT
      Content-Length: 82
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "id": 3,
                    "poNumber": "P0003",
                    "transactionalType": 1,
                    "partnershipCode": "OMS1",
                    "name": "Jafar",
                    "branchCode": "0011",
                    "loanAmount": 7000000,
                    "status": 0,
                    "statusText": "Menunggu Persetujuan PO",
                    "createdAt": "24-11-2021 17:57:11",
                    "updatedAt": "24-11-2021 17:57:13"
                },
                {
                    "id": 2,
                    "poNumber": "P0002",
                    "transactionalType": 1,
                    "partnershipCode": "AGF1",
                    "name": "Mahmudin",
                    "branchCode": "0010",
                    "loanAmount": 6000000,
                    "status": 0,
                    "statusText": "Menunggu Persetujuan PO",
                    "createdAt": "24-11-2021 17:54:03",
                    "updatedAt": "24-11-2021 17:54:26"
                }
            ],
            "desc": "Data Valid",
            "message": "Data ditemukan",
            "status": 200
        }
      '''
    }
  }
}

