example {
  name: empty data
  
  request: {
    url: {{url}}/v/1/partnerships/po-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      startIndex: 0
      recordCount: 10
      partnershipCode: AA
      transactionalType: 1
      ~textSearch: joko
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 24 Nov 2021 18:18:31 GMT
      Content-Length: 657
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "Data Purchase Order tidak ditemukan",
            "message": "Purchase Order Tidak Ditemukan",
            "status": 404
        }
      '''
    }
  }
}

example {
  name: unautorized
  
  request: {
    url: {{url}}/v/1/partnerships/po-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
