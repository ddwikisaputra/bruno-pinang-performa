example {
  name: access forbidden (403)
  
  request: {
    url: {{url}}/v/1/partnerships/po-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 15
      startIndex: 0
      recordCount: 10
      partnershipCode: IMK1
      transactionalType: 1
      ~textSearch: Dwiki
    }
  }
  
  response: {
    headers: {
      Server: nginx/1.18.0 (Ubuntu)
      Date: Mon, 25 Jul 2022 03:18:52 GMT
      Content-Type: application/json; charset=utf-8
      Content-Length: 67
      Connection: keep-alive
    }
  
    status: {
      code: 403
      text: Forbidden
    }
  
    body: {
      type: json
      content: '''
        {
            "code": 403,
            "desc": "Tidak Memliki Akses",
            "message": "403 Forbidden"
        }
      '''
    }
  }
}

