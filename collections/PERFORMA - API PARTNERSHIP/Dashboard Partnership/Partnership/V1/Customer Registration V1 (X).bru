example {
  name: error validation file size & file extension
  
  request: {
    url: {{url}}/v/1/partnerships/customer-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 
      branchCode: 
      partnershipCode: 
      ktpNumber: 
      name: 
      birthDate: 
      address: 
      mobileNumber: 
      ~email: 
      ~placeOfBirth: 
      ~motherMaidenName: 
      ~maritalStatus: 
      ~postalCode: 
      ~longitude: 
      ~latitude: 
      ~rt: 
      ~rw: 
      ~partnerName: 
      ~partneKtpNumber: 
      ~ktpBase64: 
      ~ktpMimetype: 
      ~ktpSelfieBase64: 
      ~ktpSelfieMimetype: 
      ~ktpPartnerBase64: 
      ~ktpPartnerMimetype: 
      ~businessAddress: 
      ~businessPostalCode: 
      ~businessRt: 
      ~businessRw: 
      ~callbackUrlStatus: 
      ~callbackUrlLimit: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 02:53:38 GMT
      Content-Length: 111
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Parameter ... validasi error",
            "message": "Maaf, Parameter ... file size lebih dari 100KB || Maaf, Parameter ... harus berupa image/jpeg atau image/png",
            "status": 400
        }
      '''
    }
  }
}
