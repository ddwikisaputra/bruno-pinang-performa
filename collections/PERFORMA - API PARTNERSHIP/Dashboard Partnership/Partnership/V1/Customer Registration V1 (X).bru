meta {
  name: Customer Registration V1 (X)
  type: http
  seq: 3
}

post {
  url: {{url}}/v/1/partnerships/customer-registration
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

