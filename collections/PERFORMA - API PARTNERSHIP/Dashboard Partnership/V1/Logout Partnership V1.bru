}

example {
  name: success
  
  request: {
    url: {{url}}/v/1/partnerships/logout
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      partnershipCode: OMS1
      ticketNumber: T01TMS0yMDIxMTEyMzE1NTQyMg==
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 03:03:58 GMT
      Content-Length: 82
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Logout berhasil",
            "message": "Logout berhasil",
            "status": 200
        }
      '''
    }
  }
}

