meta {
  name: Confirmation Received Purchase Order V1
  type: http
  seq: 6
}

post {
  url: {{url}}/v/1/partnerships/po-confirmation-received
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:form-urlencoded {
  referenceId: 00000071
  from: RAYAAPPS
  partnershipCode: OMS1
  userId: 009
}

settings {
  encodeUrl: true
}

example {
  name: error database connection
  
  request: {
    url: {{url}}/v/1/partnerships/po-confirmation-received
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 00000051
      from: RAYAAPPS
      partnershipCode: OMS1
      userId: 009
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 02:53:38 GMT
      Content-Length: 111
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Unable to open tcp connection with host 'localhost': dial tcp localhost: connect: connection refused",
            "message": "Server sedang dalam perbaikan. Silahkan coba beberapa saat lagi.",
            "status": 400
        }
      '''
    }
  }
}

