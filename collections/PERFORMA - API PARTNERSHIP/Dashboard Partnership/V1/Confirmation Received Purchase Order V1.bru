example {
  name: validasi po sudah ditolak
  
  request: {
    url: {{url}}/v/1/partnerships/po-confirmation-received
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 00000051
      from: RAYAAPPS
      partnershipCode: OMS1
      userId: 009
    }
  }
  
  response: {
    headers: {
      Server: nginx/1.18.0 (Ubuntu)
      Date: Wed, 13 Apr 2022 04:31:02 GMT
      Content-Type: application/json; charset=utf-8
      Content-Length: 157
      Connection: keep-alive
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "PO Status < 0 (semua status ditolak)",
            "message": "Maaf, Pengajuan anda sudah ditolak. Silahkan cek kembali status pengajuan anda.",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: validasi po bukan merchant financing
  
  request: {
    url: {{url}}/v/1/partnerships/po-confirmation-received
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 00000051
      from: RAYAAPPS
      partnershipCode: OMS1
      userId: 009
    }
  }
  
  response: {
    headers: {
      Server: nginx/1.18.0 (Ubuntu)
      Date: Wed, 13 Apr 2022 04:47:21 GMT
      Content-Type: application/json; charset=utf-8
      Content-Length: 117
      Connection: keep-alive
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Tipe bukan Merchant Financing",
            "message": "Maaf, PO tersebut tidak bertipe Merchant Financing.",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: validasi po sedang dalam proses
  
  request: {
    url: {{url}}/v/1/partnerships/po-confirmation-received
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      referenceId: 00000051
      from: RAYAAPPS
      partnershipCode: OMS1
      userId: 009
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 24 Nov 2021 18:18:31 GMT
      Content-Length: 657
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "PO Status != 1 (sedang dalam proses pengajuan)",
            "message": "Maaf, Pengajuan anda sedang dalam proses. Silahkan tunggu sampai proses pengajuan selesai.",
            "status": 500
        }
      '''
    }
  }
}

