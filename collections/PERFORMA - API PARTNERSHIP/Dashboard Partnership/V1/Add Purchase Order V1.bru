      rate: 0.5
      loanTerm: 14
      installmentPattern: 1
      administrationFee: 0
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 17 Feb 2022 07:00:27 GMT
      Content-Length: 197
    }
  
