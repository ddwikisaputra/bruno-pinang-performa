meta {
  name: Add Purchase Order V1
  type: http
  seq: 1
}

post {
  url: {{url}}/v/1/partnerships/po-add
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJkMWdpdEFMQDRnUjEiOiJhZ3JpLWFwaSIsImV4cCI6MTY3MzE1MTUyMywib3JpZ19pYXQiOjE2NzI1NDY3MjN9.QggEigDAC3J-dJQDosDhUo2Q4BaL1KyfVlDupuf_GxE
}

body:form-urlencoded {
  partnershipCode: MJ1
  poNumber: INV-DWK-DEV/01/01/23/0002
  transactionalType: 2
  name: Dwiki Saputra
  branchCode: 0020
  cifNumber: 0000118826
  facilityNumber: 0020/0000118826/PK3/018
  savingAccountNumber: 001001002278316
  referenceId: 202312
  prakarsaId: 31217
  loanAmount: 100000
  rate: 0.25
  loanTerm: 7
  installmentPattern: 1
  administrationFee: 0
}

settings {
  encodeUrl: true
}

example {
  name: validasi po sedang dalam proses (status != 0)
  
  request: {
    url: {{url}}/v/1/partnerships/po-add
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      partnershipCode: OMS1
      poNumber: PO/003
      transactionalType: 1
      name: Jumadi
      branchCode: 0010
      cifNumber: CIF003
      facilityNumber: FC003
      savingAccountNumber: DS003
      referenceId: 3
      prakarsaId: 3
      loanAmount: 500000
      rate: 0.5
      loanTerm: 7
      installmentPattern: 1
      administrationFee: 15000.00
    }
  }
  
  response: {
    headers: {
      Server: nginx/1.20.1
      Date: Wed, 01 Dec 2021 04:04:12 GMT
      Content-Type: application/json; charset=utf-8
      Content-Length: 88
      Connection: keep-alive
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "PO Status != 0 (sedang dalam proses pengajuan)",
            "message": "Maaf, Pengajuan anda sedang dalam proses. Silahkan tunggu sampai proses pengajuan selesai.",
            "status": 500
        }
      '''
    }
  }
}

