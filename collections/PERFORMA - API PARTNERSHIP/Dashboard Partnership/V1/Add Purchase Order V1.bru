      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "PO Status == 2 (berhasil pencairan)",
            "message": "Maaf, Pengajuan dengan Nomor PO tersebut sudah berhasil dicairkan. Silahkan melakukan pencairan menggunakan Nomor PO lainnya.",
            "status": 500
        }
      '''
    }
  }
}

