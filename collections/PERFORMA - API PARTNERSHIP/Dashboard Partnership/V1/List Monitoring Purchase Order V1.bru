meta {
  name: List Monitoring Purchase Order V1
  type: http
  seq: 8
}

post {
  url: {{url}}/v/1/partnerships/po-monitoring-list
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{tokenPartnership}}
}

body:form-urlencoded {
  userId: 1
  startIndex: 0
  recordCount: 5
  partnershipCode: OMS1
  ~textSearch: PO/124/MER/001
}

settings {
  encodeUrl: true
}

example {
  name: success
  
  request: {
    url: {{url}}/v/1/partnerships/po-monitoring-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      textSearch: joko
      startIndex: 0
      recordCount: 10
      partnershipCode: PST2021
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 03:03:58 GMT
      Content-Length: 82
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "id": 1,
                    "poNumber": "P0001",
                    "transactionalType": 1,
                    "partnershipCode": "OMS1",
                    "name": "Dwiki Saputra",
                    "branchCode": "0010",
                    "loanAmount": 5000000,
                    "status": 4,
                    "statusText": "Lunas",
                    "originStatus": 4,
                    "originStatusText": "Lunas",
                    "disbursementDate": "2021-12-29",
                    "dueDate": "2022-01-12",
                    "createdAt": "24-11-2021 15:42:15",
                    "updatedAt": "24-11-2021 15:42:20"
                }
            ],
            "desc": "Data Valid",
            "message": "Data ditemukan",
            "status": 200
        }
      '''
    }
  }
}

example {
  name: error parameter validation
  
  request: {
    url: {{url}}/v/1/partnerships/po-monitoring-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: User ID Login { MANDATORY }
      startIndex: 0
      recordCount: 10
      ~textSearch: joko
      ~partnershipCode: PST2021
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 02:53:38 GMT
      Content-Length: 111
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "Parameter ... kosong",
            "message": "Maaf, Parameter ... tidak boleh kosong",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: empty data
  
  request: {
    url: {{url}}/v/1/partnerships/po-monitoring-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
      startIndex: 0
      recordCount: 10
      partnershipCode: AA
      ~textSearch: joko
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 24 Nov 2021 18:18:31 GMT
      Content-Length: 657
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "Data Purchase Order tidak ditemukan",
            "message": "Purchase Order Tidak Ditemukan",
            "status": 404
        }
      '''
    }
  }
}

example {
  name: unautorized
  
  request: {
    url: {{url}}/v/1/partnerships/po-monitoring-list
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1
