meta {
  name: Request OTP Partnerhip V1
  type: http
  seq: 1
}

post {
  url: {{url}}/v/1/partnerships/request-otp
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: UmF5YVBpUGVyVG9wvQQ9yCaZywQnor3oTiEnI7QBWZVTYFT2
  password: UmF5YVBpUGVyVG9w/18dnAT+9iY6YT7toW1oEEdcvgxwAkuWwDSb
}

body:form-urlencoded {
  email: dwiki.saputra@bankraya.co.id
  mobileNumber: +6285153315772
}

settings {
  encodeUrl: true
}

example {
  name: general error
  
  request: {
    url: {{url}}/v/1/partnerships/verify-account
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      email: oms@gmail.com
      mobileNumber: +6281776527556
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 23 Jul 2021 02:53:38 GMT
      Content-Length: 111
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Could not connect .....",
            "message": "Server sedang maintenance, silahkan coba beberapa saat lagi",
            "status": 500
        }
      '''
    }
  }
}

