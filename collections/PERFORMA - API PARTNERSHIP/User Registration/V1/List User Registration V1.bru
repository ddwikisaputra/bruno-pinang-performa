example {
  name: success
  
  request: {
    url: {{url}}/v/1/partnerships/list-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 999941
      branchCode: 9999
      startIndex: 0
      recordCount: 5
      ~textSearch: oms
      ~filterDate: 2022-03-24
      ~filterStatus: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 31 May 2021 06:35:05 GMT
      Content-Length: 141
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "id": 1,
                    "name": "Dwiki Saputra Testing",
                    "position": "Pemilik",
                    "partnershipCode": "OMS1",
                    "partnershipName": "OMS",
                    "status": 0,
                    "statusText": "Menunggu Approval",
                    "createdAt": "24-03-2022 13:48:16",
                    "updatedAt": "24-03-2022 13:48:19"
                }
            ],
            "desc": "Data Valid",
            "message": "Data ditemukan",
            "status": 200
        }
      '''
    }
  }
}

example {
  name: Empty data error
  
  request: {
    url: localhost:7007/v/1/partnerships/list-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: {{userId}}
      branchCode: 9999
      startIndex: 0
      recordCount: 10
      filterDate: 2018-03-21
      filterStatus: 0
      ~textSearch: dwiki
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 29 Jan 2025 11:08:17 GMT
      Content-Length: 120
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "status": 404,
            "message": "User Registration Tidak Ditemukan",
            "desc": "Data User Registration tidak ditemukan"
        }
      '''
    }
  }
}

example {
  name: Validation param error
  
  request: {
    url: localhost:7007/v/1/partnerships/list-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      branchCode: 9999
      startIndex: 0
      recordCount: 10
      filterStatus: 0
      ~userId: {{userId}}
      ~textSearch: dwiki
      ~filterDate: 2012-03-21
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 30 Jan 2025 01:37:16 GMT
      Content-Length: 121
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Validation failed on field UserId with tag 'required'",
            "message": "Maaf, Userid Tidak Boleh Kosong",
