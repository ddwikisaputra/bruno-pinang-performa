meta {
  name: List User Registration V1
  type: http
  seq: 3
}

post {
  url: {{url}}/v/1/partnerships/list-user-registration
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{tokenPartnership}}
}

body:form-urlencoded {
  userId: {{userId}}
  branchCode: 9999
  startIndex: 0
  recordCount: 10
  filterStatus: 0
  ~textSearch: dwiki
  ~filterDate: 2012-03-21
}

settings {
  encodeUrl: true
}

example {
  name: Unauthorized
  
  request: {
    url: {{url}}/v/1/partnerships/list-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 999941
      branchCode: 9999
      startIndex: 0
      recordCount: 5
      ~textSearch: oms
      ~filterDate: 2022-03-24
      ~filterStatus: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 31 May 2021 06:32:34 GMT
      Content-Length: 108
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
            "code": 401,
            "desc": "Expired",
            "message": "Invalid Token || Token Is Expired"
        }
      '''
    }
  }
}

example {
  name: Database error
  
  request: {
    url: {{url}}/v/1/partnerships/list-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 999941
      branchCode: 9999
      startIndex: 0
      recordCount: 5
      ~textSearch: oms
      ~filterDate: 2022-03-24
      ~filterStatus: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 31 May 2021 06:32:34 GMT
      Content-Length: 108
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "Unable to open tcp connection with host 'localhost': dial tcp localhost: connect: connection refused",
            "message": "Server sedang dalam perbaikan. Silahkan coba beberapa saat lagi.",
            "status": 400
        }
      '''
    }
  }
}

