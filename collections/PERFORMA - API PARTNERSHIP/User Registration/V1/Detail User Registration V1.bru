      type: json
      content: '''
        {
            "data": {
                "id": 2,
                "name": "tes",
                "email": "tes@gmail.com",
                "mobileNumber": "+6282288194042",
                "position": "pemilik",
                "partnershipCode": "RAN20",
                "partnershipName": "",
                "level": 10,
                "userId": 49,
                "status": 1,
                "statusText": "Disetujui",
                "approvedBy": "999941",
                "rejectedBy": "",
                "createdAt": "30-03-2022 19:01:19",
                "updatedAt": "23-01-2025 07:04:18",
                "actionAt": "23-01-2025 07:04:18"
            },
            "status": 200,
            "message": "Data ditemukan",
            "desc": "Data Valid"
        }
      '''
    }
  }
}

