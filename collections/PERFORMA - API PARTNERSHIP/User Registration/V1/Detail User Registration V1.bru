meta {
  name: Detail User Registration V1
  type: http
  seq: 2
}

post {
  url: {{base-url-local}}/v/1/partnerships/detail-user-registration
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{tokenPartnership}}
}

body:form-urlencoded {
  userId: 1031212312312
  id: 1
}

settings {
  encodeUrl: true
}

example {
  name: Unauthorized
  
  request: {
    url: {{base-url-local}}/v/1/partnerships/detail-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1031212312312
      id: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 29 Jan 2025 06:17:02 GMT
      Content-Length: 75
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
            "code": 401,
            "desc": "Expired",
            "message": "Invalid Token || Token Is Expired"
        }
      '''
    }
  }
}

example {
  name: Empty Data
  
  request: {
    url: {{base-url-local}}/v/1/partnerships/detail-user-registration
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: 1031212312312
      id: 10000
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 29 Jan 2025 06:19:37 GMT
      Content-Length: 120
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "status": 404,
            "message": "User Registration Tidak Ditemukan",
            "desc": "Data User Registration tidak ditemukan"
        }
      '''
    }
  }
}

example {
  name: Success
  
  request: {
    url: {{base-url-local}}/v/1/partnerships/detail-user-registration
