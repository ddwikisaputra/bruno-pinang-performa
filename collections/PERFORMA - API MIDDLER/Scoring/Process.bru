  collateralStatusCertified: 1
}

settings {
  encodeUrl: true
}

example {
  name: 400 : Parameter Validation
  
  request: {
    url: {{url-local}}/v/1/middler/scoring/process
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: OTk5OTk5
      ktpNumber: MzE3MTA1MTIxMTk1MDAwMQ==
      uid: 1406011809860003-1187
      name: Dwiki Saputra
      phone: +62817765273711
      loanNumber: ORI-99
      scoringType: performa-musiman
      netIncome: 47.4395
      liquidationPlafond: 800.0000
      debtorStatus: lama
      installmentAmount: 120000.00
      plafond: 10000000.00
      openMonth: 2024-03-17
      collateralStatusCertified: 1
      ~longTimeBusiness: 2.0000
      ~longStay: 1.0000
      ~residentialOwnership: miliksendiri
      ~collateralOwnership: bpkb_tidak_pengikatan
      ~nationalInflation: 10.5
      ~age: 27
      ~characterBusinessConditions: memiliki_pelanggan_tetap
      ~characterOutputGoodsServices: umum_sedikit_pesaing
      ~characterBusinessTransactions: tercermin_sebagian_besar
      ~businessManagementCharacter: memiliki_karyawan
      ~levelConfidence: sesuai_kondisi_dapat_dibuktikan
      ~personalBehaviorCharacter: tidak_pernah_tersangkut_perkara_kriminal
      ~creditorQuality: selalu_lancar
      ~businessIncome: 30000000.00
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Wed, 19 Feb 2025 02:46:25 GMT
      Content-Length: 148
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Validation failed on field ... with tag '...'",
            "message": "Maaf, ... Tidak Boleh Kosong",
            "status": 400
        }
      '''
    }
  }
}

example {
  name: 500 : Server Error
  
  request: {
    url: {{url}}/v/1/middler/scoring/process
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: OTk5OTk5
      ktpNumber: MTM3MTA2MjUwMTk1MDAwOQ==
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Tue, 02 Jan 2024 04:20:46 GMT
      Content-Length: 374
    }
  
    status: {
      code: 500
      text: Internal Server Error
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": ". . . . connectex: A connection attempt failed because the connected party did not properly respond after a period of time, or established connection failed because connected host has failed to respond.",
            "message": "Maaf, Server Sedang Dalam Perbaikan. Silahkan coba beberapa saat lagi.",
            "status": 500
        }
      '''
    }
  }
}

