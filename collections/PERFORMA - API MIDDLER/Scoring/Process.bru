meta {
  name: Process
  type: http
  seq: 1
}

post {
  url: {{url-prod}}/v/1/middler/scoring/process
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: {{BasicAuthUsername}}
  password: {{BasicAuthPassword}}
}

body:form-urlencoded {
  userId: OTk5OTQx
  ktpNumber: MTM3MTA2MjUwMTk1MDAwOQ==
  uid: 1371062501950009-31415
  name: Yoga Wahyudi
  phone: +6287788194047
  loanNumber: ORI-31415
  scoringType: bigdata
  netIncome: 0.4764
  liquidationPlafond: 3780.0000
  longTimeBusiness: 0.4167
  longStay: 83.2500
  residentialOwnership: miliksendiri
  collateralOwnership: shm_tidak_pengikatan
  debtorStatus: baru
  nationalInflation: 10.5
  age: 30
  characterBusinessConditions: memiliki_pelanggan_tetap
  characterOutputGoodsServices: umum_sedikit_pesaing
  characterBusinessTransactions: tercermin_sebagian_kecil
  businessManagementCharacter: memiliki_karyawan
  levelConfidence: sesuai_kondisi_dapat_dibuktikan
