meta {
  name: Loan Expense
  type: http
  seq: 1
}

post {
  url: {{url-staging}}/v/1/middler/automation/loan-expense
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: {{BasicAuthUsername}}
  password: {{BasicAuthPassword}}
}

body:form-urlencoded {
  branchCode: 0010
  prakarsaId: MzE0MzY=
  accountNumber: 001001005390311
  adminFee: 1000.0021
  provisionFee: 2000.0022
  insuranceFee: 3000.0023
  insuranceType: MIKROADONAI
  ~userId: OTk5OTYx
}

settings {
  encodeUrl: true
}

example {
  name: 400 : Bad Request
  
  request: {
    url: {{url-local}}/v/1/middler/automation/loan-expense
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: OTk5OTYx
      kodeCabang: 0010
      prakarsaId: 31436
      accountNumber: 001001005390311
      adminFee: 1000.0021
      provisionFee: 2000.0022
      insuranceFee: 3000.0023
      insuranceType: MIKROADONAI
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 27 Jun 2024 01:20:51 GMT
      Content-Length: 129
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "desc": "Validation failed on field PrakarsaId with tag 'decode_base_64'",
            "message": "Maaf, Prakarsa Id Tidak Valid",
            "status": 400
        }
      '''
    }
  }
}

example {
  name: 400 : Bad Request
  
  request: {
    url: {{url-local}}/v/1/middler/automation/loan-expense
    method: POST
