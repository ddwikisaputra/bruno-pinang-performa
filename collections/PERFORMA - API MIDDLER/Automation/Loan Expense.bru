}

example {
  name: 500 : Inquiry Saving Account Error
  
  request: {
    url: {{url-local}}/v/1/middler/automation/loan-expense
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: OTk5OTYx
      branchCode: 0010
      prakarsaId: MzE0MzY=
      accountNumber: 001001005390377
      adminFee: 1000.0021
      provisionFee: 2000.0022
      insuranceFee: 3000.0023
      insuranceType: MIKROADONAI
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 27 Jun 2024 01:23:44 GMT
      Content-Length: 135
    }
  
    status: {
      code: 500
      text: Internal Server Error
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "desc": "record not found",
            "message": "Maaf, Server Sedang Dalam Perbaikan. Silahkan coba beberapa saat lagi.",
            "status": 500
        }
      '''
    }
  }
}

example {
  name: 200 : Success Automation Loan Expense
  
  request: {
    url: {{url-local}}/v/1/middler/automation/loan-expense
    method: POST
    mode: formUrlEncoded
    body:form-urlencoded: {
      userId: OTk5OTYx
      branchCode: 0010
      prakarsaId: MzE0MzY=
      accountNumber: 001001005390311
      adminFee: 1000.0021
      provisionFee: 2000.0022
      insuranceFee: 3000.0023
      insuranceType: MIKROADONAI
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 27 Jun 2024 01:22:57 GMT
      Content-Length: 246
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "data": {
                "statusCode": "1",
                "statusDescription": "Debet Biaya Sukses",
                "result": {
                    "adminJournalSeq": "9417523",
                    "provisionJournalSeq": "9417317",
                    "insuranceJournalSeq": "9417962"
                }
            },
            "desc": "Success Process.",
            "message": "Data Berhasil Disimpan.",
            "status": 200
        }
      '''
    }
  }
}

