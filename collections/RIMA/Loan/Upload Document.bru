meta {
  name: Upload Document
  type: http
  seq: 10
}

post {
  url: {{BASE_URL}}/v1/loan/document/upload
  body: json
  auth: bearer
}

auth:bearer {
  token: 
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
}

script:pre-request {
  const payload = {
      "loan_number": "001001008019100",
      "application_media_type_id": "RIMA-MLT-000005", 
      "file_name": "dokumen dah pokoknya",
      "src":"",
      "mime_type": "application/pdf"
  }
  
  const result = globalThis.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

settings {
  encodeUrl: true
}
