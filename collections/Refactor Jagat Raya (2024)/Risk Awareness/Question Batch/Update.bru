example {
  name: Success
  
  request: {
    url: {{BASE_URL}}/v1/risk-awareness/batch/update
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 08 Jul 2024 04:32:04 GMT
      Content-Length: 62
    }
  
    status: {
      code: 200
      text: 201
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "message": "Data berhasil diupdate",
            "status": true
        }
      '''
    }
  }
}
