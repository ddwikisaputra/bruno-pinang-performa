example {
  name: Error - Start Date < Current Date
  
  request: {
    url: {{BASE_URL}}/v1/risk-awareness/batch/create
    method: POST
    mode: multipartForm
    body:multipart-form: {
      title: Selasa Senang
      start_date: 2024-07-07
      finish_date: 2024-09-14
      file: /Users/rafqiagatha/Downloads/Format pengumpulan soal Raya ARSy.xlsx
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Tue, 09 Jul 2024 03:27:07 GMT
      Content-Length: 148
    }
  
    status: {
      code: 200
      text: 400
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "field": "START_DATE",
                    "message": "Tanggal tidak boleh kurang dari tanggal sekarang"
                }
            ],
            "message": "Terjadi kesalahan validasi",
            "status": false
        }
      '''
    }
  }
}

