meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/v1/risk-awareness/batch/create
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: 
}

body:multipart-form {
  title: Minggu Kelabu
  start_date: 2026-09-16
  finish_date: 2026-09-17
  file: /Users/hansonsiagian/Downloads/Format pengumpulan soal Raya ARSy - with header no question.xlsx
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const result = JSON.parse(JSON.parse(data))
      console.log("/v1/risk-awareness/batch/create", result)
  }
}

settings {
  encodeUrl: true
}

