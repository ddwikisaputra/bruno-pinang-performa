script:pre-request {
  const payload = {
      "question_id": "d7bed8c4-20fe-425a-9497-e895522ccb9c",
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
