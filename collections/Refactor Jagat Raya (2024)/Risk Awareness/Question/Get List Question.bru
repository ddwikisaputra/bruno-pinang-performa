meta {
  name: Get List Question
  type: http
  seq: 5
}

post {
  url: {{BASE_URL}}/v1/risk-awareness/batch/question/list
  body: json
  auth: bearer
}

auth:bearer {
  token: 
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
}

script:pre-request {
  const payload = {
      "batch_id": "958a552e-80b9-4926-8c86-4d6236a5ce1f",
      //"q": "Mengapa manajemen risiko", //(optional)
      "page": 1,
      "limit": -1 // isi -1 untuk menampilkan semua data
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const parseData = JSON.parse(data)
      const parseData2 = JSON.parse(parseData)
      console.log('/v1/risk-awareness/batch/question/list', parseData2)
  }
}

settings {
  encodeUrl: true
}

example {
  name: Error - Data Not Found
  
  request: {
    url: {{BASE_URL}}/v1/risk-awareness/batch/question/delete
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 04 Jul 2024 03:54:29 GMT
      Content-Length: 61
    }
  
    status: {
      code: 200
      text: 500
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "message": "Data tidak ditemukan",
            "status": false
        }
      '''
    }
  }
}

example {
  name: Success
  
  request: {
    url: {{BASE_URL}}/v1/risk-awareness/batch/question/list
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 05 Jul 2024 10:00:47 GMT
      Transfer-Encoding: chunked
    }
  
    status: {
      code: 200
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
            "data": "",
            "message": "Permintaan berhasil diproses",
            "status": true
        }
      '''
    }
  }
}

example {
  name: Error - Validation
  
  request: {
    url: {{BASE_URL}}/v1/risk-awareness/batch/question/list
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Fri, 05 Jul 2024 10:02:18 GMT
      Content-Length: 118
    }
  
    status: {
      code: 200
      text: 400
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "field": "BATCH_ID",
                    "message": "Batch ID harus diisi"
                }
            ],
            "message": "Terjadi kesalahan validasi",
            "status": false
        }
      '''
    }
  }
}
