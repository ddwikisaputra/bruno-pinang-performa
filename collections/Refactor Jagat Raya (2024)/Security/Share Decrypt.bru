meta {
  name: Share Decrypt
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/v1/security/share/decrypt
  body: json
  auth: none
}

headers {
  Jagat-Raya-API-Key: {{API_KEY}}
}

body:json {
  {
      "payload": ""
  }
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const parseData = JSON.parse(data)
      const parseData2 = JSON.parse(parseData)
      console.log('/v1/security/share/decrypt', parseData2)
  }
}

settings {
  encodeUrl: true
}
