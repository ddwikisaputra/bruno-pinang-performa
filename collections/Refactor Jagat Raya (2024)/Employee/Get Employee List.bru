meta {
  name: Get Employee List
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/v1/employee/list
  body: json
  auth: bearer
}

auth:bearer {
  token: 
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
}

script:pre-request {
  const payload = {
      "limit": 10,
      "page": 1,
      //"q" : "Raf" //OPTIONAL AS FILTER FOR EMPLOYEE NAME/PERSONAL NUMBER/BRANCHID
      //,
      // "personal_number":["001676", "KP000002","001475"],
      // , 
     // "jabatan_id":["080","540"], //OPTIONAL AS FILTER
      //, 
       "branch_id":["0010"], //OPTIONAL AS FILTER
      // , 
  //    "organization_id":["337"] //OPTIONAL AS FILTER
      // , 
    "status":["Tetap"] //OPTIONAL AS FILTER
  
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const parseData = JSON.parse(data)
      const parseData2 = JSON.parse(parseData)
      console.log('/v1/employee/list', parseData2)
  }
}

settings {
  encodeUrl: true
}

