meta {
  name: Get Role By Capability Identities
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/v1/role/detail/capability
  body: json
  auth: bearer
}

auth:bearer {
  token: 
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
}

script:pre-request {
  const payload = {
      "capability_identities":[
          'JGT-000001',
          'JGT-000002',
          'RYM-000004',
          'RYM-000005',
          'RYM-000003',
          'RYM-000002',
          'RYM-000001',
          'RYM-000006',
          'RYM-000010',
          'RYM-000012',
          'RYM-000013',
          'RYM-000014',
          'RYM-000015',
          'RYM-000016',
          'RYM-000018',
          'RYM-000019',
          'RYM-000020',
          'RYM-000021',
          'RYM-000022',
          'RYM-000023',
          'RYM-000024',
          'RYM-000025',
          'RYM-000027',
          'RYM-000031',
          'RYM-000032',
          'RYM-000033',
          'RYM-000009',
          'RYM-000042',
          'RYM-000043',
          'RYM-000044']
      // , // ['RYM-00001','RYM-00002','RYM-00003']
      // "application_id":"" // 'ARY','JGT','RYM' (optional)
      ,
      "is_visible": true// boolean (optional)
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const response = _.parsingJson(data)
  }
}

settings {
  encodeUrl: true
}

example {
  name: Error Not Found
  
  request: {
    url: {{BASE_URL}}/v1/role/detail/capability
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Tue, 22 Oct 2024 06:24:00 GMT
      Content-Length: 61
    }
  
    status: {
      code: 200
      text: 500
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "message": "Data tidak ditemukan",
            "status": false
        }
      '''
    }
  }
}

