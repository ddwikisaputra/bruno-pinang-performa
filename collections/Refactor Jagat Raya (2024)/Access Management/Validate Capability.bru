meta {
  name: Validate Capability
  type: http
  seq: 6
}

post {
  url: {{BASE_URL}}/v1/user/capability/validate
  body: json
  auth: bearer
}

auth:bearer {
  token: 
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
}

script:pre-request {
  const payload = {
      "capability_id":"ARAY-000001"
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const response = _.parsingJson(data)
  }
}

settings {
  encodeUrl: true
}

example {
