meta {
  name: Refresh Token
  type: http
  seq: 28
}

post {
  url: {{BASE_URL}}/v1/auth/refresh
  body: none
  auth: bearer
}

auth:bearer {
  token: 
}

script:post-response {
  const responseJSON = res.getBody()
  if (responseJSON.status) {
      const data = _.decrypt(responseJSON.data)
      const result = JSON.parse(JSON.parse(data))
      bru.setEnvVar("TOKEN", result.access_token)
      bru.setEnvVar("REFRESH_TOKEN", result.refresh_token)
      console.log("access_token : ", result.access_token)
      console.log("refresh_token : ", result.refresh_token)
  }
}

settings {
  encodeUrl: true
}

example {
  name: Success
  
  request: {
    url: {{BASE_URL}}/v1/auth/refresh-token
    method: POST
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Thu, 23 Nov 2023 11:52:54 GMT
      Content-Length: 1114
    }
  
    status: {
      code: 200
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
            "data": "",
            "message": "Permintaan berhasil diproses",
            "status": true
        }
      '''
    }
  }
}
