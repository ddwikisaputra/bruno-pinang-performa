example {
  name: Error Validation Format Email
  
  request: {
    url: {{BASE_URL}}/v1/auth/legacy/password/forgot
    method: POST
    mode: json
    body:json: {
      {
          "personal_number": "001701", // PN
          "email": "rafqi.anugrahbankraya.co.id" // Email
      }
          
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 01 Jul 2024 04:36:30 GMT
      Content-Length: 120
    }
  
    status: {
      code: 200
      text: 400
    }
  
    body: {
      type: json
      content: '''
        {
            "data": [
                {
                    "field": "EMAIL",
                    "message": "format Email tidak sesuai"
                }
            ],
            "message": "Terjadi kesalahan validasi",
            "status": false
        }
      '''
    }
  }
}

