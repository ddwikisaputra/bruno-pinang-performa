example {
  name: Decrypt - Success
  
  request: {
    url: {{BASE_URL}}/v1/auth/legacy/password/forgot
    method: POST
    mode: json
    body:json: {
      {
          "payload": "{{REQUEST_BODY}}"
      }
          
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 01 Jul 2024 07:49:32 GMT
      Content-Length: 71
    }
  
    status: {
      code: 200
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "message": "Sukses. Silahkan cek email anda",
            "status": true
        }
      '''
    }
  }
}

