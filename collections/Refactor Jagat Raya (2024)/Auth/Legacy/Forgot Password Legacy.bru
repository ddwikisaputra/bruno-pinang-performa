meta {
  name: Forgot Password Legacy
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/v1/auth/legacy/password/forgot
  body: json
  auth: none
}

body:json {
  {
      "payload": "{{REQUEST_BODY}}"
  }
  
}

script:pre-request {
  const payload = {
      "personal_number": "admin", // PN
      "email": "hanson.siagian@bankraya.co.id", // Email
  }
  
  const result = _.encrypt(JSON.stringify(payload))
  bru.setEnvVar("REQUEST_BODY", result);
}

settings {
  encodeUrl: true
}

example {
  name: Error Email Tidak Valid
  
  request: {
    url: {{BASE_URL}}/v1/auth/legacy/password/forgot
    method: POST
    mode: json
    body:json: {
      {
          "personal_number": "001701", // PN
          "email": "rafqinugrah@bankrayain.co.id" // Email
      }
          
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 01 Jul 2024 04:34:31 GMT
      Content-Length: 58
    }
  
    status: {
      code: 200
      text: 500
    }
  
    body: {
      type: json
      content: '''
        {
            "data": null,
            "message": "Email tidak valid",
            "status": false
        }
      '''
    }
  }
}

